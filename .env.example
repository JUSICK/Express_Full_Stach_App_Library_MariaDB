# ==============================================================================
# Environment Variables Example
# Please, duplicate this file to '.env' and fill in your actual credentials.
# ==============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT / Authentication
# Generate a secure string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_32_byte_hex_secret_here

# Database Configuration (Used by Node.js)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name

# Database Migration Connection String (dbmate)
DATABASE_URL=mysql://your_db_user:your_db_password@localhost:3306/your_database_name